# Newsletter SaaS - Environment Variables

# Anthropic Claude API (scoring, enrichment, newsletter generation)
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini API (keyword generation) + Gmail OAuth2
GOOGLE_API_KEY=AI...

# Tavily API (SNS content collection)
TAVILY_API_KEY=tvly-...

# Database
DATABASE_URL=sqlite:///./newsletter.db

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
